   "cell_type": "code",
   "source": [
    "# 写入标量数据\n",
    "for x in range(100):\n",
    "    writer.add_scalar('scalar/y=x', x, x)\n",
    "    writer.add_scalar('scalar/y=x^2', x ** 2, x)\n",
    "\n",
    "writer.close()"
   ],
